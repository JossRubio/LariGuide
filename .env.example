# LariGuide — Travel Planning App
# Copy this file to .env and fill in your API keys

# Groq API Key — modelo Llama 3.3 (gratuito)
# Obtén tu key en: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API Key — modelo Claude (opcional)
# Obtén tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key — modelo Gemini 2.0 Flash (opcional)
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
